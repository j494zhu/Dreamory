# ── Database (Postgres + pgvector) ───────────────────────────────
# Matches docker-compose.yml defaults.
DATABASE_URL=postgresql+asyncpg://dreamory:dreamory@localhost:5432/dreamory

# ── DeepSeek (OpenAI-compatible API) ─────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# "pro" = the heavyweight model used for generation (LLM②) & Dream naming.
# "flash" = the cheap fast model used for event extraction (LLM①).
DEEPSEEK_MODEL_PRO=deepseek-v4-pro
DEEPSEEK_MODEL_FLASH=deepseek-v4-flash
# 事件抽取(LLM①)用哪个模型:"pro" / "flash" / 任意显式模型 id。
# 0.6.1 起默认 pro:抽取误判会被 dynamics 不打折地执行,flash 省的钱不值这个险。
EXTRACTOR_MODEL=pro

# ── Embeddings ───────────────────────────────────────────────────
# "api"      -> bge-m3 over an OpenAI-compatible HTTP API (e.g. SiliconFlow) — no torch
# "bge_m3"   -> local BAAI/bge-m3 via FlagEmbedding (requires `pip install FlagEmbedding torch`)
# "fallback" -> deterministic hash embedder, zero deps, for local dev/CI
EMBEDDING_BACKEND=api
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
# used only when EMBEDDING_BACKEND=api (SiliconFlow key + base url)
EMBEDDING_API_KEY=sk-your-siliconflow-key-here
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

# ── App ──────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
# Expose per-turn affect/memory internals to the frontend debug panel.
DEBUG_PANEL=true

# ── 测试期访问控制与审计(0.6.1)──────────────────────────────────
# 空 = 鉴权关闭(本地开发)。上线测试时设置一个长随机串:
# admin 全通;每个 chat 有自己的 access_token(建 chat 时生成,
# 专属链接形如 /?chat=<id>&token=<access_token>,发给测试者)。
ADMIN_TOKEN=
# 每个 chat 滚动 24h 内的用户消息上限(成本闸;0 = 不限,上线建议 200)
DAILY_MESSAGE_LIMIT=0
# 感知/决策日志(误判审计):每轮落一行 turn_logs(GET /api/chats/{id}/turns)
TURN_LOG_ENABLED=true
# 连完整 system prompt 一起存(体积大,深度排查时才开)
TURN_LOG_FULL_PROMPT=false

# ── Memory tuning ────────────────────────────────────────────────
WORKING_MEMORY_K=10          # L1 working-memory FIFO window
RETRIEVAL_TOP_K=6            # how many L3 hits to pull per query
RETRIEVAL_MIN_SCORE=0.50     # 自动检索绝对下限(裸分数):kNN 永远凑满 K 条,低于线的底噪不进 L1 也不记热度
RETRIEVAL_MIN_SCORE_LIFE=0.60 # life_event 更高线:生活琐事归话题种子管,真聊到那件事才被自动"想起"
L2_CAPACITY=256              # Hot Zone fixed capacity (ids only)
L1_TOKEN_BUDGET=2400         # token budget for the L1 memory region
HEAT_FLUSH_SECONDS=15        # background heat write-back interval
HEAT_FLUSH_MAX_BUFFER=64     # ...or flush once this many hits buffered
HEAT_HALFLIFE_SECONDS=86400  # time-decayed heat half-life (1 day)

# ── Tagging (hot path, zero-LLM) ─────────────────────────────────
TAG_KNN_K=10                 # neighbours consulted for kNN tag propagation
TAG_VOTE_THRESHOLD=0.6       # weighted-vote cutoff to assign a tag
TAG_MAX_PER_MEMORY=5         # cap tags per memory (2-5 is the sweet spot)

# ── Timer(时间感知 + 主动消息)────────────────────────────────────
TIMER_ENABLED=true           # she can schedule "过会儿来找他" pings
TIMER_POLL_SECONDS=5         # scheduler poll interval
TIMER_MAX_PENDING=3          # max simultaneous pending pings per chat
TIMER_MAX_MINUTES=1440       # clamp on <timer minutes="X">

# ── Tools(生成端 agent loop:主动回忆 / grep / 闹钟)──────────────
TOOLS_ENABLED=true           # off = 退回 0.2.0 单次生成 + <timer> 标签
TOOL_MAX_ROUNDS=3            # 工具往返上限,超过强制作答
RETRIEVAL_CONFIDENCE=0.55    # 自动检索 top1 裸分数低于此值 → 注入"记忆很模糊"提示(须 > RETRIEVAL_MIN_SCORE)

# ── Life sim(生活模拟器:离线预生成她的线下生活)──────────────────
LIFE_SIM_ENABLED=true
LIFE_SIM_MIN_INTERVAL_HOURS=6   # 两次补写之间的最小间隔
LIFE_SIM_FRESH_TARGET=2         # 新鲜话题种子低于此数才补写
SEED_COOLDOWN_TURNS=6           # 话题种子注入的冷却轮数

# ── Schedule(日程表:作息 + 当前日程)─────────────────────────────
SCHEDULE_ENABLED=true        # off = 不注入【你的生活】,闹钟不做睡眠顺延

# ── Guardrail(守护层:防角色崩坏)─────────────────────────────────
GUARDRAIL_ENABLED=true       # 常驻【底线】块 + 输出侧检测 + 一次纠正重生成

# ── Notebook(她的小本子)─────────────────────────────────────────
NOTES_ENABLED=true           # write_note 随手记 + 夜间日记,注入 L1
NOTES_MAX_ACTIVE=12          # 活跃 note 上限(满了会拒绝,夜里自动收纳)

# ── Night agent(夜间代理)────────────────────────────────────────
NIGHT_AGENT_ENABLED=true     # 她睡着后:蒸馏当天对话/写日记/排明天/Dream
NIGHT_POLL_SECONDS=600       # 后台巡检间隔
NIGHT_IDLE_HOURS=2           # 用户静默这么久才开工
NIGHT_MIN_GAP_HOURS=20       # 每晚最多一次
NIGHT_AGENT_EDIT_ROUTINE=false  # 允许她夜里改自己的长期作息(默认只许排 oneoff)

# ── Persona evolution(好感度里程碑解锁的人格演化)─────────────────
PERSONA_EVOLUTION_ENABLED=true  # 升档时后台演化(append-only + 快照,每档一次)

# ── Commitment(承诺兑现闭环)──────────────────────────────────────
COMMITMENT_PING_ENABLED=true    # 承诺到点没兑现,她会主动催(不占 set_timer 配额)
COMMITMENT_PING_DELAY_MIN=30    # 过点多少分钟后催(到期估算本就粗,别掐秒催)

# ── Dream (offline maintenance) ──────────────────────────────────
DREAM_ENABLED=false          # built but OFF by default (per spec)


# ── Provider reference (put REAL secrets in .env, which is gitignored) ─────────
# DeepSeek (generation): models deepseek-v4-flash / deepseek-v4-pro
#   base_url: https://api.deepseek.com   · SDK: same as OpenAI
#   Enable thinking: {"thinking": {"type": "enabled/disabled"}}
#   Thinking effort: {"reasoning_effort": "high/max"}
# Embedding (bge-m3) via SiliconFlow: model BAAI/bge-m3
#   base_url: https://api.siliconflow.cn/v1
#   api docs: https://api-docs.siliconflow.cn/docs/api/embeddings-post