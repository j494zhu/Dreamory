# ── Database (Postgres + pgvector) ───────────────────────────────
# Matches docker-compose.yml defaults.
DATABASE_URL=postgresql+asyncpg://dreamory:dreamory@localhost:5432/dreamory

# ── DeepSeek (OpenAI-compatible API) ─────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# "pro" = the heavyweight model used for generation (LLM②) & Dream naming.
# "flash" = the cheap fast model used for event extraction (LLM①).
DEEPSEEK_MODEL_PRO=deepseek-v4-pro
DEEPSEEK_MODEL_FLASH=deepseek-v4-flash

# ── Embeddings ───────────────────────────────────────────────────
# "api"      -> bge-m3 over an OpenAI-compatible HTTP API (e.g. SiliconFlow) — no torch
# "bge_m3"   -> local BAAI/bge-m3 via FlagEmbedding (requires `pip install FlagEmbedding torch`)
# "fallback" -> deterministic hash embedder, zero deps, for local dev/CI
EMBEDDING_BACKEND=api
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
# used only when EMBEDDING_BACKEND=api (SiliconFlow key + base url)
EMBEDDING_API_KEY=sk-your-siliconflow-key-here
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

# ── App ──────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
# Expose per-turn affect/memory internals to the frontend debug panel.
DEBUG_PANEL=true

# ── Memory tuning ────────────────────────────────────────────────
WORKING_MEMORY_K=10          # L1 working-memory FIFO window
RETRIEVAL_TOP_K=6            # how many L3 hits to pull per query
L2_CAPACITY=256              # Hot Zone fixed capacity (ids only)
L1_TOKEN_BUDGET=2400         # token budget for the L1 memory region
HEAT_FLUSH_SECONDS=15        # background heat write-back interval
HEAT_FLUSH_MAX_BUFFER=64     # ...or flush once this many hits buffered
HEAT_HALFLIFE_SECONDS=86400  # time-decayed heat half-life (1 day)

# ── Tagging (hot path, zero-LLM) ─────────────────────────────────
TAG_KNN_K=10                 # neighbours consulted for kNN tag propagation
TAG_VOTE_THRESHOLD=0.6       # weighted-vote cutoff to assign a tag
TAG_MAX_PER_MEMORY=5         # cap tags per memory (2-5 is the sweet spot)

# ── Dream (offline maintenance) ──────────────────────────────────
DREAM_ENABLED=false          # built but OFF by default (per spec)


# ── Provider reference (put REAL secrets in .env, which is gitignored) ─────────
# DeepSeek (generation): models deepseek-v4-flash / deepseek-v4-pro
#   base_url: https://api.deepseek.com   · SDK: same as OpenAI
#   Enable thinking: {"thinking": {"type": "enabled/disabled"}}
#   Thinking effort: {"reasoning_effort": "high/max"}
# Embedding (bge-m3) via SiliconFlow: model BAAI/bge-m3
#   base_url: https://api.siliconflow.cn/v1
#   api docs: https://api-docs.siliconflow.cn/docs/api/embeddings-post